datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           String      @id @default(uuid())
  slug         String      @unique
  name         String
  description  String
  price        Float
  stock        Int         @default(0)
  sizes        String[]    // e.g. ["S", "M", "L", "XL"]
  colors       String[]    // e.g. ["Black", "Acid Wash Gray"]
  images       String[]    // URLs from MinIO S3
  categoryId   String?
  category     Category?   @relation(fields: [categoryId], references: [id])
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  orderItems   OrderItem[]
}

model Category {
  id        String    @id @default(uuid())
  slug      String    @unique
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Collection {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String?
  bannerImage String?   // MinIO URL
  isActive    Boolean   @default(true)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique // e.g. LB-2026-0001
  status          OrderStatus @default(PENDING)
  total           Float
  shippingAddress Json        // Contains address, city, zip, phone
  customerDetails Json        // Contains name, email
  paymentId       String?     // MercadoPago payment ID
  paymentStatus   String?     // MercadoPago response
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  size      String
  color     String
}

model Coupon {
  id           String       @id @default(uuid())
  code         String       @unique
  discountType DiscountType
  value        Float
  isActive     Boolean      @default(true)
  expiryDate   DateTime?
  createdAt    DateTime     @default(now())
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
